# ── 클라이언트 노출 (NEXT_PUBLIC_) ──────────────────────────────
# 카카오 JavaScript 키 — 지도 SDK 로드용 (카카오 콘솔 > 앱 키)
NEXT_PUBLIC_KAKAO_JS_KEY=
# Supabase 프로젝트 URL / anon(publishable) 키 — RLS로 보호되는 공개 키
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 서버 전용 (절대 클라이언트 노출 금지) ───────────────────────
# Anthropic API 키 — /api/* 라우트의 AI 기능(점메추/요약/온도/광고)용
ANTHROPIC_API_KEY=

# ── 로컬 스크립트 전용 (Vercel에 등록 불필요) ───────────────────
# 카카오 REST API 키 — scripts/seed*.mjs 지오코딩/장소 매칭용
KAKAO_REST_KEY=
# Supabase 서비스 롤 키 — 시딩 시 RLS 우회용 (scripts/ 전용)
SUPABASE_SERVICE_ROLE_KEY=
